# ── Ollama ──────────────────────────────────────
OLLAMA_MODEL=gpt-oss:20b-cloud
OLLAMA_TIMEOUT_SECONDS=120

# ── PostgreSQL (Docker Compose default for api) ─
# Use a strong password in real environments; compose default is "postgres" if unset.
POSTGRES_PASSWORD=postgres

# ── .NET API secrets ────────────────────────────
ADMIN_API_KEY=your-secret-key
# Optional: map to api service as Telegram__BotToken in compose override (see docker-compose comment).
TELEGRAM_BOT_TOKEN=

# ── ngrok (Telegram webhooks: public HTTPS URL; dashboard http://localhost:4040) ─
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
