{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=aiemployee;Username=aiemployee;Password=postgres"
  },
  "App": {
    "PublicBaseUrl": "https://YOUR-SUBDOMAIN.ngrok-free.app"
  },
  "Admin": {
    "ApiKey": "your-local-dev-admin-key"
  },
  "Ai": {
    "UseFullJudgePrompt": true,
    "BaseUrl": "http://localhost:8000"
  },
  "LiveNews": {
    "Enabled": true,
    "MaxHeadlines": 5,
    "MaxTitleChars": 120,
    "Language": "en",
    "Region": "US",
    "RequestTimeoutSeconds": 10,
    "UserAgent": "AiEmployeeBot/1.0",
    "TriggerKeywords": [
      "news",
      "latest",
      "breaking",
      "headlines",
      "today",
      "current events"
    ]
  },
  "Telegram": {
    "BotToken": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
