{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=aiemployee.db"
  },
  "App": {
    "PublicBaseUrl": "https://YOUR-SUBDOMAIN.ngrok-free.app"
  },
  "Admin": {
    "ApiKey": "your-local-dev-admin-key"
  },
  "Ai": {
    "UseFullJudgePrompt": true,
    "BaseUrl": "http://localhost:8000"
  },
  "LiveNews": {
    "Enabled": false,
    "MaxHeadlines": 5,
    "MaxTitleChars": 120,
    "Language": "en",
    "Region": "US",
    "RequestTimeoutSeconds": 10,
    "UserAgent": "AiEmployee/1.0 (LiveNews)",
    "TriggerKeywords": []
  },
  "Telegram": {
    "BotToken": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
