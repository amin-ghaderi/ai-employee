# Copy to .env next to docker-compose.yml (do not commit secrets).
# Reference: docs/DEPLOYMENT.md, docs/CONFIGURATION.md, docs/postgresql-cutover-phase5.md

# ── Primary database (Phase 5 default: PostgreSQL) ─────────────────────────
# docker-compose.yml already defaults Database__Provider to Npgsql for the API.
# POSTGRES_PASSWORD=your-secure-password
# Optional explicit override:
# Database__Provider=Npgsql

# ── Emergency rollback to SQLite (gitignored docker-compose.override.yml) ─
# Database__Provider=Sqlite
# ConnectionStrings__DefaultConnection=Data Source=/app/data/aiemployee.db
# Requires a valid aiemployee.db under the api api-data volume.

ADMIN_API_KEY=change-me-to-a-long-random-string
NGROK_AUTHTOKEN=

# After ngrok starts, set this to the HTTPS forwarding URL (no trailing slash), then restart api:
# APP_PUBLIC_BASE_URL=https://xxxx.ngrok-free.app

OLLAMA_MODEL=gpt-oss:20b-cloud
OLLAMA_TIMEOUT_SECONDS=120
