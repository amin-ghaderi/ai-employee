# SDK image for local Docker development with a bind-mounted repo.
# Uses `dotnet run` (no `dotnet watch`) to avoid PollingDirectoryWatcher duplicate-key
# crashes when the host tree is mounted over /app (common with Docker Desktop).
#
# Usage: docker compose --profile dev up api-dev
# -----------------------------------------------------------------------------
FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /app

COPY AiEmployee.sln ./
COPY src/AiEmployee.Api/*.csproj               src/AiEmployee.Api/
COPY src/AiEmployee.Application/*.csproj       src/AiEmployee.Application/
COPY src/AiEmployee.Domain/*.csproj            src/AiEmployee.Domain/
COPY src/AiEmployee.Infrastructure/*.csproj    src/AiEmployee.Infrastructure/
COPY tests/AiEmployee.UnitTests/*.csproj       tests/AiEmployee.UnitTests/
COPY tests/AiEmployee.IntegrationTests/*.csproj tests/AiEmployee.IntegrationTests/
RUN dotnet restore

COPY . .

EXPOSE 5155

ENTRYPOINT ["dotnet", "run", "--project", "src/AiEmployee.Api/AiEmployee.Api.csproj", "--urls", "http://0.0.0.0:5155", "--no-launch-profile"]
